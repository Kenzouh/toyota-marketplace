@{
	Layout = "~/Areas/Public/Views/Shared/_Layout.cshtml";
}

<div class="min-h-screen flex items-center justify-center ">

    <div class="backdrop-blur-md p-8 rounded-2xl shadow-2xl bg-gradient-to-br from-black via-gray-900 to-red-900 w-full max-w-md border border-red-500/30">

        <!-- Title -->
        <h2 class="text-3xl font-bold text-center text-white mb-6">
            Login
        </h2>

        <!-- Form -->
        <form class="space-y-5">

            <!-- Gmail -->
            <div>
                <label class="block text-sm text-gray-300 mb-1">Gmail *</label>
                <input type="email"
                       placeholder="Enter your email"
                       class="w-full px-4 py-2 rounded-xl bg-black/40 text-white border border-gray-600 focus:outline-none 
                        focus:ring-1 focus:ring-white focus:border-white transition" />
            </div>

            <!-- Password -->
            <div>
                <label class="block text-sm text-gray-300 mb-1">Password *</label>
                <input type="password"
                       placeholder="Enter your password"
                       class="w-full px-4 py-2 rounded-xl bg-black/40 text-white border border-gray-600 focus:outline-none 
                        focus:ring-1 focus:ring-white focus:border-white transition" />
            </div>

            <!-- Button -->
            <button type="submit"
                    class="w-full py-2 rounded-xl bg-red-600 hover:bg-red-700 text-white font-semibold transition duration-300 shadow-lg">
                Sign In
            </button>

        </form>

    </div>

</div>